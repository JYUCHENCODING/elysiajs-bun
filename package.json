{
  "name": "buntest",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest",
    "@types/pino": "^7.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.29",
    "elysia-helmet": "^3.1.0",
    "elysia-rate-limit": "^4.6.2",
    "pino": "^10.3.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched --error-on-warnings"
    ]
  }
}
